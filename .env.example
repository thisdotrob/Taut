# Slack OAuth user-token flow (primary path)
# Create a Slack app from docs/slack-app-manifest.yaml, then copy these values
# from Slack app settings → Basic Information.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Socket Mode app-level token. Generate under Slack app → Basic Information →
# App-Level Tokens with the connections:write scope.
SLACK_APP_TOKEN=xapp-...

# Must exactly match one of the Slack app OAuth redirect URLs.
# Slack requires HTTPS; replace this placeholder with your HTTPS tunnel or deployed backend URL:
SLACK_REDIRECT_URI=https://taut.example.com/api/slack/oauth/callback

# Public backend URL used to build callback URLs when SLACK_REDIRECT_URI is unset.
TAUT_PUBLIC_URL=https://taut.example.com

# Frontend URL shown after OAuth completes.
TAUT_APP_URL=http://localhost:5173

# Dev-only escape hatches. Do not use these as Rob's main Taut setup.
# Prefer the OAuth user-token flow above.
SLACK_USER_TOKEN=
SLACK_BOT_TOKEN=

# Optional; defaults to ./data/taut.db
TAUT_DB_PATH=./data/taut.db

# API port. Vite dev proxy reads TAUT_API_PORT first, then PORT, so it stays in sync.
TAUT_API_PORT=8787
# PORT=8787

# Optional real LLM triage/drafting. If unset, Taut keeps using heuristic-v0.
TAUT_LLM_PROVIDER=openai
OPENAI_API_KEY=
TAUT_LLM_MODEL=gpt-5.6
TAUT_LLM_MAX_OUTPUT_TOKENS=900

# Optional incremental Slack backfill depth when a conversation has a stored Slack watermark.
TAUT_HISTORY_MAX_PAGES=3
